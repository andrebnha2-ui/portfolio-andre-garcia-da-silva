{
  "entities": {
    "HistoryItem": {
      "title": "History Item",
      "description": "A record of a metadata analysis performed by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the person who performed the analysis." },
        "type": { "type": "string", "enum": ["file", "url"], "description": "The type of analysis performed." },
        "source": { "type": "string", "description": "The name of the file or the URL analyzed." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the analysis was performed." },
        "metadataCount": { "type": "number", "description": "Number of metadata tags found." },
        "metadata": { "type": "object", "description": "The full metadata result object." }
      },
      "required": ["uid", "type", "source", "timestamp", "metadata"]
    }
  },
  "firestore": {
    "/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Collection of analysis history records."
    }
  }
}
